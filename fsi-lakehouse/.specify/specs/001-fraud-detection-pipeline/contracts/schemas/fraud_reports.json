{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FraudReport",
  "description": "Fraud label for transactions (ML training data)",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Transaction ID reference"
    },
    "is_fraud": {
      "type": "integer",
      "enum": [0, 1],
      "description": "Fraud indicator (1=fraud, 0=legitimate)"
    }
  },
  "required": ["id", "is_fraud"]
}
